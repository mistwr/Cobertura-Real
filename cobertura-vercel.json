{
  "rewrites": [
    { "source": "/api/anacom", "destination": "/api/anacom.js" },
    { "source": "/api/moradas", "destination": "/api/moradas.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS" }
      ]
    }
  ]
}
